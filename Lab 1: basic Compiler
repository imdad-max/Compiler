#include<bits/stdc++.h>
using namespace std;

struct symbolinfo
{
    string name;
    string type;
};

class symboltable
{
    vector<symbolinfo>vec[10];

public:


    int hashfunction(string name)
    {
        int sum=0;
        int len=name.length();
        for(int i=0; i<len; i++)
        {
            sum+=name[i];
        }
        return sum%10;
    }


    void insertt(string name, string type)
    {
        symbolinfo ob;

        ob.name = name;
        ob.type = type;

        int hashval= hashfunction(name);

        vector<symbolinfo>v = vec[hashval];

        int x= lookup(name);


        if(x)
        {
            cout<<"Already inserted"<<endl;
        }
        else
        {
            vec[hashval].push_back(ob);
            cout<<"Symbol inserted"<<endl;
        }

    }

    int lookup(string name)
    {
        int hashval= hashfunction(name);

        vector<symbolinfo>v = vec[hashval];

        for(auto it: v)
        {
            if(it.name==name)
            {
                return 1;
            }
        }
        return 0;
    }


    void deletee(string name, string type)
    {
        int hashval =hashfunction(name);
        for(int i= 0; i<vec[hashval].size(); i++)
        {
            if(vec[hashval][i].name==name && vec[hashval][i].type==type)
            {
                vec[hashval].erase(vec[hashval].begin()+1);
                cout<<"deletion done"<<endl;
            }
        }
    }

    void print()
    {
        cout<<endl;

        for(int i= 0; i<10; i++)
        {
            for(auto x: vec[i])
            {
                cout<< "<" << x.name << "," <<x.type<< ">" << endl;
            }
        }
    }

};

int main()
{
    symboltable s;
    s.insertt("int","keyword");
    s.insertt("a","id");
    s.deletee("a","id");
    s.insertt("b","id");
    s.insertt("c","id");

    s.print();


}
